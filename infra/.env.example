# Copy to .env and fill in. Read by docker-compose.yml.

# Production domain(s) for Caddy's automatic HTTPS. Unset = local HTTP on :8080.
# SITE_ADDRESS=markhaoxiang.com, www.markhaoxiang.com

# Host key for catan-render. When set, only people who type this string into the
# game dialog's "Host key" field can create games; anyone can still join an
# existing game via its invite link. Leave unset to let anyone create games.
# CATAN_CREATE_KEY=change-me
