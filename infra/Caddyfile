# Site address comes from SITE_ADDRESS in infra/.env.
# Unset (local development) it defaults to plain HTTP on localhost:8080.
# Production: SITE_ADDRESS=markhaoxiang.com, www.markhaoxiang.com
{$SITE_ADDRESS:localhost:8080} {
	encode gzip

	# Projects mount under paths. handle_path strips the prefix before
	# proxying, so the upstream sees requests rooted at /; the project's
	# build sets the matching base path (catan: vite --base=/catan/ via
	# the image's BASE_PATH build arg, FastAPI ROOT_PATH=/catan).
	handle_path /catan/* {
		reverse_proxy catan:8000
	}

	handle {
		root * /srv/site
		try_files {path} /index.html
		file_server
	}
}
