{
  "name": "mark-haoxiang-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "smoke": "vite build --logLevel error --outDir node_modules/.smoke-dist --emptyOutDir",
    "check": "tsc -b && eslint . && vitest run && npm run --silent smoke",
    "prepare": "git -C .. config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  }
}
